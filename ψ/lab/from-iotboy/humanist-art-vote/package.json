{
  "name": "humanist-art-vote",
  "version": "0.1.0",
  "private": true,
  "description": "humanist.art/vote — Cloudflare Workers + D1 + Drizzle backend, Vite + React + Tailwind monochrome frontend. Lifts pattern from Soul-Brews-Studio/webhook-relay-oss; voice from buildwithoracle.com.",
  "scripts": {
    "dev": "wrangler dev",
    "build": "vite build",
    "deploy": "npm run build && wrangler deploy",
    "db:gen": "drizzle-kit generate",
    "db:push:local": "wrangler d1 execute humanist_vote --local --file ./migrations/0000_init.sql",
    "db:push:prod": "wrangler d1 execute humanist_vote --remote --file ./migrations/0000_init.sql"
  },
  "dependencies": {
    "hono": "^4.7.0",
    "drizzle-orm": "^0.36.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250101.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "drizzle-kit": "^0.28.0",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "wrangler": "^3.100.0"
  }
}
